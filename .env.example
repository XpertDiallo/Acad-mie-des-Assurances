# Sécurité
JWT_SECRET=changez-cette-valeur-par-une-chaine-longue-et-aleatoire
ACCESS_TOKEN_MINUTES=720

# URLs
PUBLIC_APP_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8080
DATABASE_URL=sqlite:////data/academie.db

# Tuteur documentaire (optionnel, ne jamais exposer la clé dans le navigateur)
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
GROQ_MODEL_FALLBACK=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_STT_MODEL=whisper-large-v3-turbo

# Index documentaire local
# tfidf : léger et sans téléchargement de modèle
# semantic : nécessite backend/requirements-semantic.txt
EMBEDDING_PROVIDER=tfidf
SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
