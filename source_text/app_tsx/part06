function GrantModal({user,token,onClose,onSaved}:{user:any;token:string|null;onClose:()=>void;onSaved:()=>void}){const{data:modules}=useAsync(()=>api<ModuleSummary[]>('/api/modules',{},token),[token]);const[form,setForm]=useState({module_slug:'',plan:'module',payment_reference:'',amount:'5000'});const[busy,setBusy]=useState(false);const[error,setError]=useState('');async function submit(e:FormEvent){e.preventDefault();setBusy(true);try{await api('/api/admin/access',{method:'POST',body:JSON.stringify({user_id:user.id,module_slug:form.plan==='module'?form.module_slug:null,plan:form.plan,payment_reference:form.payment_reference||null,amount:Number(form.amount)})},token);onSaved()}catch(e){setError((e as Error).message)}finally{setBusy(false)}}return <div className="modal-backdrop"><div className="modal compact"><button className="modal-close" onClick={onClose}><X/></button><span className="eyebrow">Gestion des droits</span><h2>Activer l’accès de {user.first_name}</h2><ErrorBox message={error}/><form onSubmit={submit}><label>Formule<select value={form.plan} onChange={e=>setForm({...form,plan:e.target.value,amount:e.target.value==='module'?'5000':e.target.value==='monthly'?'30000':'250000'})}><option value="module">Par module</option><option value="monthly">Mensuelle</option><option value="annual">Annuelle</option></select></label>{form.plan==='module'&&<label>Module<select required value={form.module_slug} onChange={e=>setForm({...form,module_slug:e.target.value})}><option value="">Choisir...</option>{modules?.filter(m=>!m.is_free).map(m=><option value={m.slug} key={m.slug}>{m.title}</option>)}</select></label>}<label>Référence de paiement<input value={form.payment_reference} onChange={e=>setForm({...form,payment_reference:e.target.value})} placeholder="Ex. OM-2026-00142"/></label><label>Montant reçu (FCFA)<input type="number" value={form.amount} onChange={e=>setForm({...form,amount:e.target.value})}/></label><button disabled={busy} className="btn btn-primary full">{busy?'Activation...':'Valider et activer'}</button></form></div></div>}

function AuditPage(){const{token}=useAuth();const{data,loading,error}=useAsync(()=>api<any[]>('/api/audit',{},token),[token]);return <><div className="page-head"><div><span className="eyebrow">Traçabilité</span><h1>Journal d’activité</h1><p>Les principales opérations sensibles sont conservées dans un journal horodaté.</p></div></div><ErrorBox message={error}/>{loading?<LoadingScreen/>:<div className="timeline">{data?.map(row=><article key={row.id}><span className="timeline-dot"/><div><strong>{row.action}</strong><p>{row.target}</p><small>{new Date(row.created_at).toLocaleString('fr-FR')} • Acteur #{row.actor_id||'système'}</small></div></article>)}</div>}</>}

function PedagogyDashboard(){const{token}=useAuth();const{data,loading,error}=useAsync(()=>api<any>('/api/pedagogy/overview',{},token),[token]);if(loading)return<LoadingScreen/>;return <><div className="page-head"><div><span className="eyebrow">Qualité pédagogique</span><h1>Vue pédagogique</h1><p>Contrôlez les contenus, les évaluations et la cohérence du catalogue.</p></div><Link className="btn btn-primary" to="/app/pedagogy/modules"><BookOpen/> Réviser les modules</Link></div><ErrorBox message={error}/><div className="stat-grid"><StatCard icon={<Library/>} value={data?.modules.length||0} label="Modules" tone="navy"/><StatCard icon={<ClipboardCheck/>} value={data?.modules.reduce((s:number,m:any)=>s+m.questions,0)||0} label="Questions validées" tone="green"/><StatCard icon={<MessageCircleQuestion/>} value={data?.recent_questions||0} label="Questions d’auditeurs" tone="gold"/><StatCard icon={<GraduationCap/>} value={data?.exam_attempts||0} label="Examens réalisés" tone="coral"/></div><div className="module-quality-grid">{data?.modules.map((m:any)=><article key={m.slug}><div className="module-icon">{moduleThemes[m.slug]?.icon}</div><div><span className={`status ${m.published?'active':'inactive'}`}>{m.published?'Publié':'Suspendu'}</span><h3>{m.title}</h3><p>{m.lesson_count} leçons • {m.questions} QCM • {Math.round(m.characters/1000)}k caractères</p><ProgressBar value={100} label="Contenu structuré"/></div><Link className="round-link" to="/app/pedagogy/modules"><ChevronRight/></Link></article>)}</div></>}

function PedagogyModules(){const{token}=useAuth();const{data,loading,error,reload}=useAsync(()=>api<any>('/api/pedagogy/overview',{},token),[token]);const[selected,setSelected]=useState<any>(null);async function toggle(module:any){await api(`/api/pedagogy/modules/${module.slug}`,{method:'PATCH',body:JSON.stringify({published:!module.published})},token);reload()}return <><div className="page-head"><div><span className="eyebrow">Gestion éditoriale</span><h1>Modules et contenus</h1><p>Révisez les métadonnées, le statut de publication et les leçons.</p></div></div><ErrorBox message={error}/>{loading?<LoadingScreen/>:<div className="editor-grid">{data?.modules.map((m:any)=><article className="editor-module" key={m.slug}><div className="module-icon">{moduleThemes[m.slug]?.icon}</div><div><span className={`status ${m.published?'active':'inactive'}`}>{m.published?'Publié':'Suspendu'}</span><h3>{m.title}</h3><p>{m.lesson_count} leçons • Version {m.version}</p></div><div className="editor-actions"><button className="icon-btn" onClick={()=>toggle(m)} title="Changer le statut">{m.published?<Lock/>:<Check/>}</button><button className="btn btn-small btn-ghost" onClick={()=>setSelected(m)}>Modifier</button></div></article>)}</div>}{selected&&<ModuleEditModal module={selected} token={token} onClose={()=>setSelected(null)} onSaved={()=>{setSelected(null);reload()}}/>}</>}

function ModuleEditModal({module,token,onClose,onSaved}:{module:any;token:string|null;onClose:()=>void;onSaved:()=>void}){const[form,setForm]=useState({title:module.title,description:module.description,price_fcfa:module.price_fcfa});const[busy,setBusy]=useState(false);async function submit(e:FormEvent){e.preventDefault();setBusy(true);await api(`/api/pedagogy/modules/${module.slug}`,{method:'PATCH',body:JSON.stringify(form)},token);setBusy(false);onSaved()}return <div className="modal-backdrop"><div className="modal"><button className="modal-close" onClick={onClose}><X/></button><span className="eyebrow">Fiche du module</span><h2>Modifier les informations</h2><form onSubmit={submit}><label>Titre<input value={form.title} onChange={e=>setForm({...form,title:e.target.value})}/></label><label>Description<textarea rows={5} value={form.description} onChange={e=>setForm({...form,description:e.target.value})}/></label><label>Tarif par module (FCFA)<input type="number" value={form.price_fcfa} onChange={e=>setForm({...form,price_fcfa:Number(e.target.value)})}/></label><button disabled={busy} className="btn btn-primary full"><Save/> Enregistrer</button></form></div></div>}

function PedagogyQuestions(){const{token}=useAuth();const{data:modules}=useAsync(()=>api<ModuleSummary[]>('/api/modules',{},token),[token]);const[module,setModule]=useState('');const{data,loading,error,reload}=useAsync(()=>api<any[]>(`/api/pedagogy/questions${module?`?module_slug=${module}`:''}`,{},token),[token,module]);const[editing,setEditing]=useState<any>(null);return <><div className="page-head"><div><span className="eyebrow">Évaluations</span><h1>Banque de QCM</h1><p>Chaque question contient quatre propositions, une bonne réponse et une correction expliquée.</p></div><button className="btn btn-primary" onClick={()=>setEditing({new:true})}><Plus/> Ajouter une question</button></div><ErrorBox message={error}/><div className="toolbar"><select value={module} onChange={e=>setModule(e.target.value)}><option value="">Tous les modules</option>{modules?.map(m=><option value={m.slug} key={m.slug}>{m.title}</option>)}</select><span>{data?.length||0} questions</span></div>{loading?<LoadingScreen/>:<div className="question-bank">{data?.map(q=><article key={q.id}><div><span className="badge badge-soft">{q.difficulty}</span><span className={`status ${q.active?'active':'inactive'}`}>{q.active?'Active':'Suspendue'}</span></div><h3>{q.prompt}</h3><ol type="A">{q.options.map((o:string,i:number)=><li className={i===q.correct_index?'right':''} key={o}>{o}{i===q.correct_index&&<Check/>}</li>)}</ol><p className="explanation"><strong>Correction :</strong> {q.explanation}</p><button className="btn btn-small btn-ghost" onClick={()=>setEditing(q)}>Modifier</button></article>)}</div>}{editing&&<QuestionEditModal question={editing} modules={modules||[]} token={token} onClose={()=>setEditing(null)} onSaved={()=>{setEditing(null);reload()}}/>}</>}

