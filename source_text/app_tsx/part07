function QuestionEditModal({question,modules,token,onClose,onSaved}:{question:any;modules:ModuleSummary[];token:string|null;onClose:()=>void;onSaved:()=>void}){const isNew=question.new;const[firstModule,setFirstModule]=useState(modules[0]?.slug||'');const{data:detail}=useAsync(()=>firstModule?api<ModuleDetail>(`/api/modules/${firstModule}`,{},token):Promise.resolve(null),[firstModule,token]);const[form,setForm]=useState({lesson_id:question.lesson_id||'',prompt:question.prompt||'',options:question.options||['','','',''],correct_index:question.correct_index||0,explanation:question.explanation||'',difficulty:question.difficulty||'fondamental',active:question.active??true});const[busy,setBusy]=useState(false);async function submit(e:FormEvent){e.preventDefault();setBusy(true);if(isNew)await api('/api/pedagogy/questions',{method:'POST',body:JSON.stringify(form)},token);else await api(`/api/pedagogy/questions/${question.id}`,{method:'PATCH',body:JSON.stringify(form)},token);setBusy(false);onSaved()}return <div className="modal-backdrop"><div className="modal"><button className="modal-close" onClick={onClose}><X/></button><span className="eyebrow">{isNew?'Nouvelle question':'Révision de question'}</span><h2>{isNew?'Ajouter un QCM':'Modifier le QCM'}</h2><form onSubmit={submit}>{isNew&&<><label>Module<select value={firstModule} onChange={e=>{setFirstModule(e.target.value);setForm({...form,lesson_id:''})}}>{modules.map(m=><option value={m.slug} key={m.slug}>{m.title}</option>)}</select></label><label>Leçon<select required value={form.lesson_id} onChange={e=>setForm({...form,lesson_id:e.target.value})}><option value="">Choisir...</option>{detail?.lessons.map(l=><option value={l.id} key={l.id}>{l.title}</option>)}</select></label></>}<label>Énoncé<textarea required rows={3} value={form.prompt} onChange={e=>setForm({...form,prompt:e.target.value})}/></label>{form.options.map((o:string,i:number)=><label key={i}>Proposition {String.fromCharCode(65+i)}<div className="option-edit"><input required value={o} onChange={e=>{const options=[...form.options];options[i]=e.target.value;setForm({...form,options})}}/><input type="radio" name="correct" checked={form.correct_index===i} onChange={()=>setForm({...form,correct_index:i})}/><span>Bonne réponse</span></div></label>)}<label>Explication détaillée<textarea required rows={4} value={form.explanation} onChange={e=>setForm({...form,explanation:e.target.value})}/></label><div className="form-row"><label>Difficulté<select value={form.difficulty} onChange={e=>setForm({...form,difficulty:e.target.value})}><option>fondamental</option><option>intermédiaire</option><option>avancé</option></select></label><label className="checkbox-label"><input type="checkbox" checked={form.active} onChange={e=>setForm({...form,active:e.target.checked})}/> Question active</label></div><button className="btn btn-primary full" disabled={busy}><Save/> Enregistrer la question</button></form></div></div>}

function NotFound(){return <div className="empty-state"><BookOpen/><h1>Page introuvable</h1><p>La page demandée n’existe pas ou n’est plus disponible.</p><Link className="btn btn-primary" to="/">Retour à l’accueil</Link></div>}

export default function App(){return <Routes>
  <Route path="/" element={<LandingPage/>}/><Route path="/login" element={<AuthPage mode="login"/>}/><Route path="/register" element={<AuthPage mode="register"/>}/><Route path="/verify/:code" element={<VerifyPage/>}/>
  <Route path="/app" element={<ProtectedRoute><AppLayout><DashboardRouter/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/modules" element={<ProtectedRoute roles={['student']}><AppLayout><ModulesPage/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/modules/:slug" element={<ProtectedRoute roles={['student']}><AppLayout><CourseOverview/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/modules/:slug/lesson/:lessonId" element={<ProtectedRoute roles={['student']}><LessonPlayer/></ProtectedRoute>}/>
  <Route path="/app/modules/:slug/exam" element={<ProtectedRoute roles={['student']}><AppLayout><ExamPage/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/certificates" element={<ProtectedRoute roles={['student']}><AppLayout><CertificatesPage/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/admin/users" element={<ProtectedRoute roles={['admin']}><AppLayout><AdminUsers/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/admin/audit" element={<ProtectedRoute roles={['admin']}><AppLayout><AuditPage/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/pedagogy/modules" element={<ProtectedRoute roles={['pedagogy']}><AppLayout><PedagogyModules/></AppLayout></ProtectedRoute>}/>
  <Route path="/app/pedagogy/questions" element={<ProtectedRoute roles={['pedagogy']}><AppLayout><PedagogyQuestions/></AppLayout></ProtectedRoute>}/>
  <Route path="*" element={<NotFound/>}/>
</Routes>}
