function ExamPage(){const{slug}=useParams();const{token}=useAuth();const{data,loading,error}=useAsync(()=>api<any>(`/api/modules/${slug}/exam`,{},token),[slug,token]);const[answers,setAnswers]=useState<Record<string,number>>({});const[result,setResult]=useState<any>(null);const[busy,setBusy]=useState(false);async function submit(){if(!confirm('Confirmer la remise de votre examen ?'))return;setBusy(true);try{setResult(await api(`/api/modules/${slug}/exam/submit`,{method:'POST',body:JSON.stringify({answers})},token))}finally{setBusy(false)}}if(loading)return<LoadingScreen/>;return <div className="exam-page"><Link className="back-link" to={`/app/modules/${slug}`}><ChevronLeft/> Retour au module</Link><div className="page-head"><div><span className="eyebrow">Évaluation finale</span><h1>Examen du module</h1><p>{data?.questions.length||0} questions • {data?.duration_minutes} minutes • seuil de réussite {data?.pass_score}/100</p></div><span className="timer"><Clock3/> 30:00</span></div><ErrorBox message={error}/>{!result?<><div className="exam-questions">{data?.questions.map((q:QuizQuestion,qi:number)=><article key={q.id}><div className="question-count">Question {qi+1} / {data.questions.length}</div><h3>{q.prompt}</h3>{q.options.map((o,oi)=><label key={o} className={answers[q.id]===oi?'selected':''}><input type="radio" checked={answers[q.id]===oi} name={q.id} onChange={()=>setAnswers({...answers,[q.id]:oi})}/><span>{String.fromCharCode(65+oi)}</span>{o}</label>)}</article>)}</div><button className="btn btn-primary exam-submit" disabled={busy||Object.keys(answers).length!==(data?.questions.length||0)} onClick={submit}>{busy?'Calcul du résultat...':'Remettre mon examen'} <ClipboardCheck/></button></>:<div className="final-result"><div className={`score-ring large ${result.passed?'success':'warning'}`}><strong>{result.score}</strong><span>/100</span></div><h2>{result.passed?'Félicitations !':'Continuez vos révisions'}</h2><p>{result.message}</p>{result.certificate&&<div className="certificate-ready"><Award/><div><strong>Votre attestation est prête</strong><span>N° {result.certificate.number}</span></div></div>}<div><Link className="btn btn-primary" to="/app/certificates">Voir mes attestations</Link><Link className="btn btn-ghost" to={`/app/modules/${slug}`}>Retour au module</Link></div></div>}</div>}

function CertificatesPage(){const{token}=useAuth();const{data,loading,error}=useAsync(()=>api<any[]>('/api/certificates',{},token),[token]);async function download(id:number,number:string){const res=await fetch(`/api/certificates/${id}/download`,{headers:{Authorization:`Bearer ${token}`}});if(!res.ok)return alert('Téléchargement impossible');const blob=await res.blob();const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=`${number}.pdf`;a.click();URL.revokeObjectURL(url)}return <><div className="page-head"><div><span className="eyebrow">Réussites</span><h1>Mes attestations</h1><p>Retrouvez et téléchargez les attestations obtenues après vos examens.</p></div></div><ErrorBox message={error}/>{loading?<LoadingScreen/>:data?.length?<div className="cert-grid">{data.map(c=><article className="cert-card" key={c.id}><Award/><div><span className="badge badge-free">Valide</span><h3>{c.module_title}</h3><p>Note obtenue : <strong>{c.score}/100</strong></p><small>{c.number}</small><small>Délivrée le {new Date(c.issued_at).toLocaleDateString('fr-FR')}</small></div><button className="btn btn-primary" onClick={()=>download(c.id,c.number)}>Télécharger le PDF</button></article>)}</div>:<div className="empty-state"><Award/><h2>Aucune attestation pour le moment</h2><p>Terminez un module et obtenez au moins 70/100 à l’examen final.</p><Link className="btn btn-primary" to="/app/modules">Voir les formations</Link></div>}</>}

function VerifyPage(){const{code}=useParams();const{data,loading}=useAsync(()=>api<any>(`/api/verify/${code}`),[code]);return <div className="verify-page"><Link to="/" className="brand"><span className="brand-mark">AA</span><span>Académie des Assurances</span></Link>{loading?<LoadingScreen/>:<div className={`verify-card ${data?.valid?'valid':'invalid'}`}>{data?.valid?<ShieldCheck/>:<X/>}<span className="eyebrow">Vérification publique</span><h1>{data?.valid?'Attestation authentique':'Attestation non valide'}</h1>{data?.valid?<div className="verify-details"><p><span>Bénéficiaire</span><strong>{data.holder}</strong></p><p><span>Formation</span><strong>{data.module_title}</strong></p><p><span>Note</span><strong>{data.score}/100</strong></p><p><span>Numéro</span><strong>{data.number}</strong></p><p><span>Date</span><strong>{new Date(data.issued_at).toLocaleDateString('fr-FR')}</strong></p></div>:<p>{data?.message||'Ce code ne correspond à aucune attestation active.'}</p>}<Link className="btn btn-primary" to="/">Retour à l’accueil</Link></div>}</div>}

function AdminDashboard(){const{token}=useAuth();const{data,loading,error}=useAsync(()=>api<any>('/api/admin/stats',{},token),[token]);if(loading)return<LoadingScreen/>;return <><div className="page-head"><div><span className="eyebrow">Pilotage de la plateforme</span><h1>Vue générale</h1><p>Suivez les accès, les utilisateurs et l’activité de formation.</p></div><Link className="btn btn-primary" to="/app/admin/users"><Users/> Gérer les comptes</Link></div><ErrorBox message={error}/><div className="stat-grid"><StatCard icon={<Users/>} value={data?.users||0} label="Comptes inscrits" tone="navy"/><StatCard icon={<ShieldCheck/>} value={data?.active_users||0} label="Comptes actifs" tone="green"/><StatCard icon={<Award/>} value={data?.certificates||0} label="Attestations délivrées" tone="gold"/><StatCard icon={<MessageCircleQuestion/>} value={data?.chat_questions||0} label="Questions posées" tone="coral"/></div><div className="dashboard-panels"><article className="panel"><div className="panel-head"><h2>Actions prioritaires</h2></div><div className="action-list"><Link to="/app/admin/users"><KeyRound/><div><strong>Activer les accès après paiement</strong><span>Attribuer un module ou un abonnement</span></div><ChevronRight/></Link><Link to="/app/admin/audit"><ShieldCheck/><div><strong>Contrôler le journal d’activité</strong><span>Vérifier les opérations administratives récentes</span></div><ChevronRight/></Link></div></article><article className="panel"><div className="panel-head"><h2>État du MVP</h2></div><ul className="status-list"><li><Check/> Quatre modules intégrés</li><li><Check/> Authentification et rôles opérationnels</li><li><Check/> Paiement hors plateforme</li><li><Check/> Attestations vérifiables</li><li><Check/> Sauvegarde de progression</li></ul></article></div></>}

function AdminUsers(){const{token}=useAuth();const{data,loading,error,reload}=useAsync(()=>api<any[]>('/api/admin/users',{},token),[token]);const[search,setSearch]=useState('');const[grant,setGrant]=useState<{user:any}|null>(null);const filtered=(data||[]).filter(u=>`${u.first_name} ${u.last_name} ${u.email}`.toLowerCase().includes(search.toLowerCase()));async function toggle(user:any){await api(`/api/admin/users/${user.id}/status?active=${!user.active}`,{method:'PATCH'},token);reload()}return <><div className="page-head"><div><span className="eyebrow">Administration</span><h1>Utilisateurs et accès</h1><p>Activez les comptes et attribuez les droits après réception du paiement.</p></div></div><ErrorBox message={error}/><div className="toolbar"><div className="search-input"><Search/><input placeholder="Rechercher un utilisateur..." value={search} onChange={e=>setSearch(e.target.value)}/></div></div>{loading?<LoadingScreen/>:<div className="table-wrap"><table><thead><tr><th>Utilisateur</th><th>Rôle</th><th>Statut</th><th>Accès</th><th>Actions</th></tr></thead><tbody>{filtered.map(u=><tr key={u.id}><td><div className="user-cell"><div className="avatar small">{u.first_name[0]}{u.last_name[0]}</div><span><strong>{u.first_name} {u.last_name}</strong><small>{u.email}</small></span></div></td><td>{roleLabels[u.role]}</td><td><span className={`status ${u.active?'active':'inactive'}`}>{u.active?'Actif':'Désactivé'}</span></td><td><div className="access-chips">{u.access?.map((a:any)=><span key={a.module_slug}>{a.module_title}</span>)}{!u.access?.length&&<small>Aucun module payant</small>}</div></td><td><div className="table-actions"><button className="icon-btn" title="Attribuer un accès" onClick={()=>setGrant({user:u})}><KeyRound/></button><button className="icon-btn" title={u.active?'Désactiver':'Activer'} onClick={()=>toggle(u)}>{u.active?<Lock/>:<Check/>}</button></div></td></tr>)}</tbody></table></div>}{grant&&<GrantModal user={grant.user} token={token} onClose={()=>setGrant(null)} onSaved={()=>{setGrant(null);reload()}}/>}</>}

