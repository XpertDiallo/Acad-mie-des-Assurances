      </section>
      {showCoach && <CoachPanel lesson={lesson} onClose={()=>setShowCoach(false)} initialSummary={!!lesson.progress?.segment_index}/>} 
    </div>
    {showQuiz&&<QuizModal lesson={lesson} token={token} onClose={()=>setShowQuiz(false)}/>} 
  </div>
}

function CoachPanel({lesson,onClose,initialSummary}:{lesson:LessonDetail;onClose:()=>void;initialSummary:boolean}){
  const {token}=useAuth(); const [question,setQuestion]=useState(''); const [busy,setBusy]=useState(false); const [listening,setListening]=useState(false); const [mode,setMode]=useState('clarification')
  const [messages,setMessages]=useState<TutorMessage[]>([{role:'tutor',text:'Bonjour ! Je suis votre tuteur pour cette leçon. Demandez-moi une explication, un exemple, un rappel théorique ou les pièges à éviter.'}])
  const scrollRef=useRef<HTMLDivElement>(null)
  useEffect(()=>scrollRef.current?.scrollTo({top:scrollRef.current.scrollHeight,behavior:'smooth'}),[messages])
  useEffect(()=>{if(initialSummary){setMessages(m=>[...m,{role:'tutor',text:'Vous reprenez une séance précédente. Cliquez sur « Résumer » pour revoir rapidement les notions déjà parcourues.'}])}},[initialSummary])
  async function ask(custom?:string,customMode?:string){const q=(custom||question).trim();if(!q)return;setBusy(true);setQuestion('');setMessages(m=>[...m,{role:'student',text:q}]);try{const response=await api<{answer:string;sources:{lesson_title:string;excerpt:string}[]}>('/api/tutor/ask',{method:'POST',body:JSON.stringify({module_slug:lesson.module_slug,lesson_id:lesson.id,question:q,mode:customMode||mode})},token);setMessages(m=>[...m,{role:'tutor',text:response.answer,sources:response.sources}])}catch(e){setMessages(m=>[...m,{role:'tutor',text:`Je n’ai pas pu répondre : ${(e as Error).message}`}])}finally{setBusy(false)}}
  function voiceInput(){const Ctor=window.SpeechRecognition||window.webkitSpeechRecognition;if(!Ctor){setMessages(m=>[...m,{role:'tutor',text:'La saisie vocale n’est pas disponible dans ce navigateur. Vous pouvez écrire votre question.'}]);return}const recognition=new Ctor();recognition.lang='fr-FR';recognition.interimResults=false;recognition.continuous=false;recognition.onresult=e=>{setQuestion(e.results[0][0].transcript);setListening(false)};recognition.onerror=()=>setListening(false);recognition.onend=()=>setListening(false);setListening(true);recognition.start()}
  const modes=[['clarification','Clarifier'],['simple','Simplifier'],['example','Exemple'],['trap','Pièges'],['summary','Résumer']]
  return <aside className="coach-panel"><div className="coach-head"><div><span className="coach-avatar"><MessageCircleQuestion/></span><div><strong>Tuteur pédagogique</strong><small>{lesson.title}</small></div></div><button className="icon-btn" onClick={onClose}><X/></button></div><div className="coach-modes">{modes.map(([value,label])=><button className={mode===value?'active':''} key={value} onClick={()=>{setMode(value);if(value==='summary')ask('Résume les notions étudiées dans cette leçon.','summary')}}>{label}</button>)}</div><div className="chat-stream" ref={scrollRef}>{messages.map((m,i)=><div key={i} className={`chat-message ${m.role}`}><div>{m.text.split('\n').map((line,j)=><p key={j}>{line}</p>)}</div>{m.sources&&<details><summary>Sources du cours</summary>{m.sources.map((s,j)=><section key={j}><strong>{s.lesson_title}</strong><p>{s.excerpt}</p></section>)}</details>}</div>)}{busy&&<div className="typing"><i/><i/><i/></div>}</div><form className="chat-input" onSubmit={e=>{e.preventDefault();ask()}}><textarea value={question} onChange={e=>setQuestion(e.target.value)} placeholder="Posez votre question..." rows={2}/><button type="button" className={`icon-btn mic ${listening?'listening':''}`} onClick={voiceInput}>{listening?<Square/>:<Mic/>}</button><button disabled={busy||!question.trim()} className="send-btn" type="submit"><ChevronRight/></button></form></aside>
}

function QuizModal({lesson,token,onClose}:{lesson:LessonDetail;token:string|null;onClose:()=>void}){
  const {data,loading,error}=useAsync(()=>api<{questions:QuizQuestion[]}>(`/api/lessons/${lesson.id}/quiz`,{},token),[lesson.id,token]); const [answers,setAnswers]=useState<Record<string,number>>({}); const [result,setResult]=useState<any>(null); const [busy,setBusy]=useState(false)
  async function submit(){setBusy(true);try{setResult(await api('/api/quizzes/submit',{method:'POST',body:JSON.stringify({lesson_id:lesson.id,answers})},token))}finally{setBusy(false)}}
  return <div className="modal-backdrop"><div className="modal quiz-modal"><button className="modal-close" onClick={onClose}><X/></button><span className="eyebrow">Validation de la leçon</span><h2>QCM : {lesson.title}</h2><p>Choisissez une réponse pour chaque question. La correction détaillée apparaît après validation.</p><ErrorBox message={error}/>{loading?<LoadingScreen/>:!result?<div className="quiz-list">{data?.questions.map((q,qi)=><article key={q.id}><strong>{qi+1}. {q.prompt}</strong>{q.options.map((o,oi)=><label className={answers[q.id]===oi?'selected':''} key={o}><input type="radio" name={q.id} checked={answers[q.id]===oi} onChange={()=>setAnswers({...answers,[q.id]:oi})}/><span>{String.fromCharCode(65+oi)}</span>{o}</label>)}</article>)}<button disabled={busy||Object.keys(answers).length!==(data?.questions.length||0)} className="btn btn-primary full" onClick={submit}>{busy?'Correction...':'Valider mes réponses'}</button></div>:<div className="quiz-result"><div className={`score-ring ${result.score>=70?'success':'warning'}`}><strong>{result.score}</strong><span>/100</span></div><h3>{result.score>=70?'Leçon maîtrisée !':'Une révision est recommandée'}</h3>{result.details.map((d:any,i:number)=><article className={d.is_correct?'correct':'incorrect'} key={d.id}><strong>{d.is_correct?<Check/>:<X/>} Question {i+1}</strong><p>{d.explanation}</p><small>Bonne réponse : {d.options[d.correct_index]}</small></article>)}<button className="btn btn-primary full" onClick={onClose}>Poursuivre</button></div>}</div></div>
}

