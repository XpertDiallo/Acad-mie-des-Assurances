@app.post(f"{API_PREFIX}/admin/access")
def grant_access(payload: AccessGrantIn, admin: User = Depends(require_roles("admin")), db: Session = Depends(get_db)) -> dict[str, Any]:
    target = db.get(User, payload.user_id)
    if not target:
        raise HTTPException(status_code=404, detail="Utilisateur introuvable")
    if payload.module_slug:
        modules = [db.scalar(select(CourseModule).where(CourseModule.slug == payload.module_slug))]
        if not modules[0]:
            raise HTTPException(status_code=404, detail="Module introuvable")
    else:
        modules = list(db.scalars(select(CourseModule).where(CourseModule.is_free.is_(False))))
    days = payload.days or (30 if payload.plan == "monthly" else 365 if payload.plan == "annual" else 365)
    expiry = datetime.now(timezone.utc) + timedelta(days=days) if payload.plan in {"monthly", "annual"} else None
    for module in modules:
        row = db.scalar(select(Enrollment).where(Enrollment.user_id == target.id, Enrollment.module_id == module.id))
        if not row:
            row = Enrollment(user_id=target.id, module_id=module.id, source=payload.plan, granted_by=admin.id)
            db.add(row)
        row.source = payload.plan
        row.granted_by = admin.id
        row.expires_at = expiry
    if payload.payment_reference:
        payment = Payment(
            user_id=target.id, module_id=modules[0].id if len(modules) == 1 else None, plan=payload.plan,
            amount=payload.amount or (5000 if payload.plan == "module" else 30000 if payload.plan == "monthly" else 250000),
            reference=payload.payment_reference, status="validated", validated_by=admin.id,
        )
        db.add(payment)
    audit(db, admin.id, "access.grant", f"user:{target.id}", {"modules": [m.slug for m in modules], "plan": payload.plan})
    db.commit()
    return {"granted": True, "modules": [m.slug for m in modules], "expires_at": expiry}


@app.delete(f"{API_PREFIX}/admin/access/{{user_id}}/{{module_slug}}")
def revoke_access(user_id: int, module_slug: str, admin: User = Depends(require_roles("admin")), db: Session = Depends(get_db)) -> dict[str, Any]:
    module = db.scalar(select(CourseModule).where(CourseModule.slug == module_slug))
    if not module:
        raise HTTPException(status_code=404, detail="Module introuvable")
    row = db.scalar(select(Enrollment).where(Enrollment.user_id == user_id, Enrollment.module_id == module.id))
    if row:
        db.delete(row)
        audit(db, admin.id, "access.revoke", f"user:{user_id}", {"module": module_slug})
        db.commit()
    return {"revoked": True}


