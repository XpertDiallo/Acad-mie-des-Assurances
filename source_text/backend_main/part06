@app.patch(f"{API_PREFIX}/pedagogy/modules/{{slug}}")
def update_module(slug: str, payload: ModuleUpdateIn, pedagogy: User = Depends(require_roles("admin", "pedagogy")), db: Session = Depends(get_db)) -> dict[str, Any]:
    module = db.scalar(select(CourseModule).where(CourseModule.slug == slug))
    if not module:
        raise HTTPException(status_code=404, detail="Module introuvable")
    for field, value in payload.model_dump(exclude_none=True).items():
        setattr(module, field, value)
    module.version += 1
    audit(db, pedagogy.id, "module.update", f"module:{slug}", payload.model_dump(exclude_none=True))
    db.commit(); course_index.cache.pop(module.id, None)
    return serialize_module(db, module, pedagogy, include_lessons=True)


