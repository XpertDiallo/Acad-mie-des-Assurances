def has_module_access(db: Session, user: User, module: CourseModule) -> bool:
    if user.role in {"admin", "pedagogy"}:
        return True
    if module.is_free:
        return True
    enrollment = db.scalar(select(Enrollment).where(Enrollment.user_id == user.id, Enrollment.module_id == module.id))
    if not enrollment:
        return False
    if enrollment.expires_at is None:
        return True
    expiry = enrollment.expires_at
    if expiry.tzinfo is None:
        expiry = expiry.replace(tzinfo=timezone.utc)
    return expiry > datetime.now(timezone.utc)


