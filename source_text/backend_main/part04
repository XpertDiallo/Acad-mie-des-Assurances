def get_module(slug: str, user: User = Depends(current_user), db: Session = Depends(get_db)) -> dict[str, Any]:
    module = db.scalar(select(CourseModule).where(CourseModule.slug == slug))
    if not module or (not module.published and user.role == "student"):
        raise HTTPException(status_code=404, detail="Module introuvable")
    return serialize_module(db, module, user, include_lessons=True)


@app.get(f"{API_PREFIX}/lessons/{{lesson_id}}")
def get_lesson(lesson_id: str, user: User = Depends(current_user), db: Session = Depends(get_db)) -> dict[str, Any]:
    lesson = db.get(Lesson, lesson_id)
    if not lesson:
        raise HTTPException(status_code=404, detail="Leçon introuvable")
    module = db.get(CourseModule, lesson.module_id)
    if not module or not has_module_access(db, user, module):
        raise HTTPException(status_code=403, detail="Ce module nécessite une activation")
    progress = db.scalar(select(Progress).where(Progress.user_id == user.id, Progress.lesson_id == lesson.id))
    return {
        "id": lesson.id, "module_slug": module.slug, "module_title": module.title, "order": lesson.order,
        "title": lesson.title, "summary": lesson.summary, "content": lesson.content,
        "estimated_minutes": lesson.estimated_minutes,
        "progress": {"segment_index": progress.segment_index, "segment_count": progress.segment_count, "completed": progress.completed, "quiz_score": progress.quiz_score} if progress else None,
    }


@app.put(f"{API_PREFIX}/progress/{{lesson_id}}")
def save_progress(lesson_id: str, payload: ProgressIn, user: User = Depends(current_user), db: Session = Depends(get_db)) -> dict[str, Any]:
    lesson = db.get(Lesson, lesson_id)
    if not lesson:
        raise HTTPException(status_code=404, detail="Leçon introuvable")
    module = db.get(CourseModule, lesson.module_id)
    if not module or not has_module_access(db, user, module):
        raise HTTPException(status_code=403, detail="Accès non activé")
    row = db.scalar(select(Progress).where(Progress.user_id == user.id, Progress.lesson_id == lesson_id))
    if not row:
        row = Progress(user_id=user.id, lesson_id=lesson_id)
        db.add(row)
    row.segment_count = max(1, payload.segment_count)
    row.segment_index = max(0, min(payload.segment_index, row.segment_count - 1))
    row.completed = payload.completed or row.completed
    row.last_seen = datetime.now(timezone.utc)
    db.commit()
    return {"saved": True, "module_progress": module_progress(db, user.id, module)}


@app.get(f"{API_PREFIX}/lessons/{{lesson_id}}/quiz")
def lesson_quiz(lesson_id: str, user: User = Depends(current_user), db: Session = Depends(get_db)) -> dict[str, Any]:
    lesson = db.get(Lesson, lesson_id)
    if not lesson:
        raise HTTPException(status_code=404, detail="Leçon introuvable")
    module = db.get(CourseModule, lesson.module_id)
    if not module or not has_module_access(db, user, module):
        raise HTTPException(status_code=403, detail="Accès non activé")
