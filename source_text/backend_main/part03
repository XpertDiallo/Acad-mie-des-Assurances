@app.get(f"{API_PREFIX}/modules")
def list_modules(
    authorization: str | None = Header(default=None),
    db: Session = Depends(get_db),
) -> list[dict[str, Any]]:
    user = None
    if authorization:
        try:
            token = bearer_token(authorization)
            payload = jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGORITHM])
            user = db.get(User, int(payload["sub"]))
        except Exception:
            user = None
    modules = list(db.scalars(select(CourseModule).where(CourseModule.published.is_(True)).order_by(CourseModule.id)))
    return [serialize_module(db, module, user, include_lessons=False) for module in modules]


